---
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Unchained — End human trafficking and modern slavery with a global network of advocates, survivors, and organizations." />
    <meta property="og:title" content="Unchained — End Human Trafficking" />
    <meta property="og:description" content="Join the global movement to end human trafficking. Connect with advocates, organizations, and survivors worldwide." />
    <meta property="og:image" content="https://unchained.vercel.app/og-image.png" />
    <meta property="og:url" content="https://unchained.vercel.app" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Unchained — End Human Trafficking" />
    <meta name="twitter:description" content="Global movement to end human trafficking and modern slavery." />
    <meta name="twitter:image" content="https://unchained.vercel.app/og-image.png" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&family=Playfair+Display:wght@600;700;900&family=Caveat:wght@700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='75' font-size='75' fill='%23d4a574'>🕊</text></svg>" />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-[999] focus:bg-gold focus:text-black focus:px-4 focus:py-2 focus:font-bold">
      Skip to main content
    </a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --black: #0a0a0a;
    --charcoal: #1a1a1a;
    --gold: #d4a574;
    --gold-light: #e8c9a0;
    --mauve: #8b6f8e;
    --mauve-light: #b8a0b8;
    --cream: #f5f1e8;
    --gray-dark: #3a3a3a;
    --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
    --ease-in-out: cubic-bezier(0.77, 0, 0.175, 1);
    --ease-drawer: cubic-bezier(0.32, 0.72, 0, 1);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: linear-gradient(180deg, #0a0a0a 0%, #1a1a1a 100%);
    color: var(--cream);
    font-family: 'Geist', sans-serif;
    overflow-x: hidden;
    position: relative;
  }

  /* Film-grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" /></filter><rect width="100" height="100" filter="url(%23noise)" opacity="0.02" /></svg>');
    pointer-events: none;
    z-index: 1;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    letter-spacing: -2px;
  }

  a {
    color: var(--gold);
    text-decoration: none;
    transition: color 200ms ease-out;
  }

  a:hover {
    color: var(--gold-light);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }

  /* Accessibility: Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .focus\:not-sr-only:focus {
    position: static;
    width: auto;
    height: auto;
    padding: inherit;
    margin: inherit;
    overflow: visible;
    clip: auto;
    white-space: normal;
  }
</style>
