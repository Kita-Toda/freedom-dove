---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us — Unchained">
  <div class="min-h-screen bg-gradient-to-b from-black to-charcoal py-32 px-4 md:px-12">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-20">
        <a href="/" class="inline-flex items-center text-gold hover:text-gold-light transition mb-8">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
          Back to Home
        </a>

        <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
          Our Story
        </div>
        <h1 class="text-6xl md:text-7xl font-black text-cream leading-tight mb-8" style="letter-spacing: -2px;">
          About Unchained
        </h1>
        <p class="text-xl text-cream/80 max-w-2xl">
          A global movement ending human trafficking and modern slavery through advocacy, survivor support, and data-driven policy.
        </p>
      </div>

      <!-- Mission Statement -->
      <section class="mb-20 border-t border-gold/20 pt-16">
        <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
          Our Mission
        </div>
        <h2 class="text-4xl font-bold text-cream mb-8">Ending Exploitation Worldwide</h2>
        <p class="text-lg text-cream/80 leading-relaxed mb-6">
          An Estimated 49.6 Million People Are Currently Trapped In Modern Slavery—Forced Labor, Debt Bondage, Child Trafficking, And Sexual Exploitation. Unchained Is A Global Network Of Organizations, Advocates, And Survivors Working To Break These Chains.
        </p>
        <p class="text-lg text-cream/80 leading-relaxed">
          We Believe Freedom Is A Fundamental Right. We Connect Resources, Share Intelligence, Support Survivors, And Demand Policy Change From Governments And Corporations.
        </p>
      </section>

      <!-- Core Values -->
      <section class="mb-20 border-t border-gold/20 pt-16">
        <h2 class="text-4xl font-bold text-cream mb-12">Our Core Values</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-charcoal/50 border border-gold/30 rounded-2xl p-8">
            <div class="text-3xl text-gold font-bold mb-4">🕊️</div>
            <h3 class="text-xl font-bold text-cream mb-3">Survivor-Led</h3>
            <p class="text-cream/80">Survivors Hold Leadership Positions. Their Lived Experience Informs Every Decision We Make.</p>
          </div>

          <div class="bg-charcoal/50 border border-mauve/30 rounded-2xl p-8">
            <div class="text-3xl text-mauve-light font-bold mb-4">🔍</div>
            <h3 class="text-xl font-bold text-cream mb-3">Data-Driven</h3>
            <p class="text-cream/80">Evidence & Research Guide Our Advocacy. We Share Intelligence Securely With Law Enforcement Partners.</p>
          </div>

          <div class="bg-charcoal/50 border border-gold-light/30 rounded-2xl p-8">
            <div class="text-3xl text-gold-light font-bold mb-4">🤝</div>
            <h3 class="text-xl font-bold text-cream mb-3">Collaborative</h3>
            <p class="text-cream/80">No Single Organization Can End Trafficking. We Partner With NGOs, Governments, And Private Sector Allies.</p>
          </div>

          <div class="bg-charcoal/50 border border-cream/30 rounded-2xl p-8">
            <div class="text-3xl text-cream font-bold mb-4">📊</div>
            <h3 class="text-xl font-bold text-cream mb-3">Transparent</h3>
            <p class="text-cream/80">Full Financial Accountability. We Publish Annual Reports And Fund Allocation Breakdowns Publicly.</p>
          </div>
        </div>
      </section>

      <!-- What We Do -->
      <section class="mb-20 border-t border-gold/20 pt-16">
        <h2 class="text-4xl font-bold text-cream mb-12">What We Do</h2>

        <div class="space-y-12">
          <div class="relative pl-8 border-l-2 border-gold">
            <div class="absolute -left-4 -top-1 w-6 h-6 bg-gold rounded-full"></div>
            <h3 class="text-2xl font-bold text-gold mb-3">Direct Survivor Services</h3>
            <p class="text-cream/80 leading-relaxed">
              We Fund Safe Housing, Psychological Counseling, Legal Aid, Job Training, And Vocational Placement For Survivors Rebuilding Their Lives.
            </p>
          </div>

          <div class="relative pl-8 border-l-2 border-mauve">
            <div class="absolute -left-4 -top-1 w-6 h-6 bg-mauve rounded-full"></div>
            <h3 class="text-2xl font-bold text-mauve-light mb-3">Demand for Justice</h3>
            <p class="text-cream/80 leading-relaxed">
              Through Coordinated Campaigns, We Pressure Governments To Strengthen Anti-Trafficking Laws And Corporations To Adopt Ethical Supply Chains.
            </p>
          </div>

          <div class="relative pl-8 border-l-2 border-gold-light">
            <div class="absolute -left-4 -top-1 w-6 h-6 bg-gold-light rounded-full"></div>
            <h3 class="text-2xl font-bold text-gold-light mb-3">Data & Intelligence Sharing</h3>
            <p class="text-cream/80 leading-relaxed">
              Our Secure Platform Enables Law Enforcement Across 31 Countries To Share Trafficking Patterns, Suspect Information, And Survivor Leads—Resulting In 847 Convictions Since 2019.
            </p>
          </div>

          <div class="relative pl-8 border-l-2 border-cream">
            <div class="absolute -left-4 -top-1 w-6 h-6 bg-cream rounded-full"></div>
            <h3 class="text-2xl font-bold text-cream mb-3">Research & Advocacy</h3>
            <p class="text-cream/80 leading-relaxed">
              We Publish Peer-Reviewed Research On Trafficking Trends, Survivor Resilience, And Policy Effectiveness. Our Findings Shape International Anti-Trafficking Strategy.
            </p>
          </div>
        </div>
      </section>

      <!-- Stats -->
      <section class="mb-20 border-t border-gold/20 pt-16">
        <h2 class="text-4xl font-bold text-cream mb-12">By The Numbers</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-charcoal/50 border border-gold/30 rounded-2xl p-12 text-center">
            <div class="text-5xl font-black text-gold mb-2">31</div>
            <div class="text-cream/80 uppercase text-sm tracking-widest font-semibold">Countries Active</div>
          </div>

          <div class="bg-charcoal/50 border border-mauve/30 rounded-2xl p-12 text-center">
            <div class="text-5xl font-black text-mauve-light mb-2">847</div>
            <div class="text-cream/80 uppercase text-sm tracking-widest font-semibold">Traffickers Convicted</div>
          </div>

          <div class="bg-charcoal/50 border border-gold-light/30 rounded-2xl p-12 text-center">
            <div class="text-5xl font-black text-gold-light mb-2">127K+</div>
            <div class="text-cream/80 uppercase text-sm tracking-widest font-semibold">Survivors Supported</div>
          </div>

          <div class="bg-charcoal/50 border border-cream/30 rounded-2xl p-12 text-center">
            <div class="text-5xl font-black text-cream mb-2">$47M</div>
            <div class="text-cream/80 uppercase text-sm tracking-widest font-semibold">Direct Services Funded</div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="border-t border-gold/20 pt-16 text-center">
        <h2 class="text-4xl font-bold text-cream mb-8">Join the Movement</h2>
        <p class="text-lg text-cream/80 mb-8 max-w-2xl mx-auto">
          Freedom Is Not A Luxury—It's A Right. Every Person, Organization, And Government Can Play A Role In Ending Slavery.
        </p>
        <a href="/get-involved" class="inline-block px-12 py-5 bg-gold text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-wider">
          Get Involved
        </a>
      </section>
    </div>
  </div>
</Layout>
