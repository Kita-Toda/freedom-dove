---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Involved — Unchained">
  <div class="min-h-screen bg-gradient-to-b from-black to-charcoal py-32 px-4 md:px-12">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-20">
        <a href="/" class="inline-flex items-center text-gold hover:text-gold-light transition mb-8">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Home
        </a>

        <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
          Take Action
        </div>
        <h1 class="text-6xl md:text-7xl font-black text-cream leading-tight mb-8" style="letter-spacing: -2px;">
          Get Involved
        </h1>
        <p class="text-xl text-cream/80 max-w-2xl">
          There Are Many Ways To Join The Movement For Freedom. Whether You Have Resources, Expertise, Or Passion—We Need You.
        </p>
      </div>

      <!-- Action Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
        <!-- Donate -->
        <div class="group">
          <div class="relative bg-charcoal/50 border border-gold/30 rounded-3xl p-12 hover:border-gold/60 transition-colors duration-300 h-full">
            <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">💝</div>
            <h2 class="text-3xl font-bold text-gold mb-4">Donate</h2>
            <p class="text-cream/80 leading-relaxed mb-8">
              Every Dollar Funds Direct Survivor Services: Safe Housing, Counseling, Legal Aid, And Vocational Training. 100% transparency—see exactly where your support goes.
            </p>
            <ul class="space-y-3 text-cream/70 text-sm mb-8">
              <li class="flex items-start">
                <span class="text-gold mr-3">✓</span>
                <span>Tax-deductible donations (501(c)(3))</span>
              </li>
              <li class="flex items-start">
                <span class="text-gold mr-3">✓</span>
                <span>Monthly giving programs available</span>
              </li>
              <li class="flex items-start">
                <span class="text-gold mr-3">✓</span>
                <span>Donate via card, wire, or crypto</span>
              </li>
            </ul>
            <a href="https://donate.unchained.org" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-3 bg-gold text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-wider">
              Donate Now
            </a>
          </div>
        </div>

        <!-- Volunteer -->
        <div class="group">
          <div class="relative bg-charcoal/50 border border-mauve/30 rounded-3xl p-12 hover:border-mauve/60 transition-colors duration-300 h-full">
            <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">🤝</div>
            <h2 class="text-3xl font-bold text-mauve-light mb-4">Volunteer</h2>
            <p class="text-cream/80 leading-relaxed mb-8">
              Contribute your professional skills: legal expertise, software development, mental health counseling, job placement services, or grant writing.
            </p>
            <ul class="space-y-3 text-cream/70 text-sm mb-8">
              <li class="flex items-start">
                <span class="text-mauve-light mr-3">✓</span>
                <span>Remote or in-person opportunities</span>
              </li>
              <li class="flex items-start">
                <span class="text-mauve-light mr-3">✓</span>
                <span>Flexible time commitment</span>
              </li>
              <li class="flex items-start">
                <span class="text-mauve-light mr-3">✓</span>
                <span>Monthly skill-share workshops</span>
              </li>
            </ul>
            <a href="https://volunteer.unchained.org" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-3 bg-mauve text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-wider">
              Apply to Volunteer
            </a>
          </div>
        </div>

        <!-- Partner -->
        <div class="group">
          <div class="relative bg-charcoal/50 border border-gold-light/30 rounded-3xl p-12 hover:border-gold-light/60 transition-colors duration-300 h-full">
            <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">🌐</div>
            <h2 class="text-3xl font-bold text-gold-light mb-4">Partner With Us</h2>
            <p class="text-cream/80 leading-relaxed mb-8">
              Organizations, governments, and corporations partner with us on research, policy advocacy, survivor support programs, and supply chain transparency initiatives.
            </p>
            <ul class="space-y-3 text-cream/70 text-sm mb-8">
              <li class="flex items-start">
                <span class="text-gold-light mr-3">✓</span>
                <span>Co-develop programs with us</span>
              </li>
              <li class="flex items-start">
                <span class="text-gold-light mr-3">✓</span>
                <span>Access our research & data</span>
              </li>
              <li class="flex items-start">
                <span class="text-gold-light mr-3">✓</span>
                <span>Align your impact with ours</span>
              </li>
            </ul>
            <a href="mailto:partnerships@unchained.org" class="inline-block px-8 py-3 bg-gold-light text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-wider">
              Get in Touch
            </a>
          </div>
        </div>

        <!-- Advocate -->
        <div class="group">
          <div class="relative bg-charcoal/50 border border-cream/30 rounded-3xl p-12 hover:border-cream/60 transition-colors duration-300 h-full">
            <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">📢</div>
            <h2 class="text-3xl font-bold text-cream mb-4">Advocate</h2>
            <p class="text-cream/80 leading-relaxed mb-8">
              Use your platform, voice, or influence to amplify survivor stories and demand policy change. Sign petitions, share resources, contact representatives.
            </p>
            <ul class="space-y-3 text-cream/70 text-sm mb-8">
              <li class="flex items-start">
                <span class="text-cream mr-3">✓</span>
                <span>Join our advocacy network</span>
              </li>
              <li class="flex items-start">
                <span class="text-cream mr-3">✓</span>
                <span>Access fact sheets & toolkits</span>
              </li>
              <li class="flex items-start">
                <span class="text-cream mr-3">✓</span>
                <span>Monthly policy briefings</span>
              </li>
            </ul>
            <a href="https://advocate.unchained.org" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-3 border-2 border-cream text-cream font-bold rounded-full hover:bg-cream hover:text-black transition-all duration-200 uppercase text-sm tracking-wider">
              Join the Network
            </a>
          </div>
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="border-t border-gold/20 pt-20">
        <h2 class="text-4xl font-bold text-cream mb-12">Frequently Asked Questions</h2>

        <div class="space-y-8">
          <div class="group">
            <button class="w-full flex items-center justify-between text-left mb-4 hover:text-gold transition">
              <h3 class="text-lg font-bold text-cream">Is my donation tax-deductible?</h3>
              <span class="text-gold text-2xl">+</span>
            </button>
            <p class="text-cream/80 leading-relaxed hidden group-hover:block">
              Yes! Unchained is a registered 501(c)(3) nonprofit organization. You'll receive a tax receipt for all donations.
            </p>
          </div>

          <div class="group">
            <button class="w-full flex items-center justify-between text-left mb-4 hover:text-gold transition">
              <h3 class="text-lg font-bold text-cream">Do volunteers need prior experience?</h3>
              <span class="text-gold text-2xl">+</span>
            </button>
            <p class="text-cream/80 leading-relaxed hidden group-hover:block">
              We welcome people at all skill levels. We provide training for all volunteer roles and match you to opportunities that fit your background.
            </p>
          </div>

          <div class="group">
            <button class="w-full flex items-center justify-between text-left mb-4 hover:text-gold transition">
              <h3 class="text-lg font-bold text-cream">What's your overhead & admin cost?</h3>
              <span class="text-gold text-2xl">+</span>
            </button>
            <p class="text-cream/80 leading-relaxed hidden group-hover:block">
              12% of revenue goes to operations. 88% funds direct survivor services. Full financial reports published annually on our site.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .group:hover h3 + span {
    transform: rotate(45deg);
  }
</style>
