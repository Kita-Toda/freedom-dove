---
import Layout from '../layouts/Layout.astro';
import DoveScene from '../components/DoveScene';
---

<Layout title="Unchained — End Human Trafficking">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-[999] focus:bg-gold focus:text-black focus:px-4 focus:py-2 focus:font-bold">
    Skip to main content
  </a>

  <div id="main" class="relative z-10">
    <!-- Hero Section with Dove -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden bg-gradient-to-b from-black via-black to-charcoal">
      <!-- Background imagery (subtle, blurred) -->
      <div class="absolute inset-0 opacity-30 pointer-events-none">
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-gold/5 to-transparent"></div>
        <div class="absolute top-1/4 right-0 w-96 h-96 rounded-full blur-3xl" style="background: radial-gradient(circle, rgba(212,165,116,0.15) 0%, transparent 70%)"></div>
        <div class="absolute bottom-1/4 left-0 w-96 h-96 rounded-full blur-3xl" style="background: radial-gradient(circle, rgba(139,111,142,0.15) 0%, transparent 70%)"></div>
      </div>

      <DoveScene client:load />

      <div class="absolute inset-0 flex flex-col items-center justify-center text-center pointer-events-none">
        <div class="animate-fade-in-up mb-6">
          <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-4">
            Humanitarian Initiative
          </div>
          <h1 class="text-8xl md:text-9xl font-black text-gold leading-none mb-6" style="letter-spacing: -3px;">
            UNCHAINED
          </h1>
          <p class="text-xl text-cream font-light tracking-widest max-w-2xl mx-auto">
            For the forgotten. For the voiceless. For a world without chains.
          </p>
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 pointer-events-none">
        <div class="animate-bounce text-gold opacity-60">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </div>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="min-h-screen py-32 px-4 md:px-12 bg-gradient-to-b from-black to-charcoal relative z-20">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div class="scroll-reveal">
            <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
              Our Mission
            </div>
            <h2 class="text-6xl md:text-7xl font-black text-cream leading-tight mb-8" style="letter-spacing: -2px;">
              Breaking Chains
            </h2>
            <p class="text-xl text-cream/80 leading-relaxed mb-8 max-w-xl">
              We believe in the fundamental right to freedom for all human beings. Our platform connects advocates, organizations, and communities working to end exploitation and trafficking.
            </p>
            <div class="flex gap-4">
              <a href="#action" class="px-8 py-4 bg-gold text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-wider">
                Get Involved
              </a>
              <a href="#impact" class="px-8 py-4 border-2 border-gold text-gold font-bold rounded-full hover:bg-gold hover:text-black transition-all duration-200 uppercase text-sm tracking-wider">
                Learn More
              </a>
            </div>
          </div>

          <div class="scroll-reveal delay-200">
            <div class="relative">
              <div class="absolute -inset-4 bg-gradient-to-r from-gold to-mauve opacity-20 blur-2xl rounded-3xl"></div>
              <div class="relative bg-charcoal border-2 border-gold/30 rounded-3xl p-12 backdrop-blur-sm">
                <div class="text-center">
                  <div class="text-5xl font-black text-gold mb-2">49.6M</div>
                  <div class="text-cream/80 uppercase text-sm tracking-widest">In Modern Slavery Today</div>
                  <div class="text-cream/50 text-xs mt-3 font-light">Per UN ILO estimates 2024</div>
                  <div class="h-1 w-16 bg-gradient-to-r from-gold to-mauve mx-auto mt-6"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Impact Section -->
    <section id="impact" class="min-h-screen py-32 px-4 md:px-12 relative z-20">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-20">
          <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6 scroll-reveal">
            Global Impact
          </div>
          <h2 class="text-6xl md:text-7xl font-black text-cream leading-tight scroll-reveal" style="letter-spacing: -2px;">
            Our Work Across Continents
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            {
              number: '31',
              label: 'Countries',
              desc: 'Networks active across 4 continents',
              borderColor: 'border-gold/40',
              accentColor: 'text-gold',
              glowColor: 'from-gold/25 to-gold/10',
            },
            {
              number: '127,340',
              label: 'Survivors Supported',
              desc: 'Direct services, housing, legal aid',
              borderColor: 'border-mauve/40',
              accentColor: 'text-mauve-light',
              glowColor: 'from-mauve/25 to-mauve/10',
            },
            {
              number: '847',
              label: 'Traffickers Convicted',
              desc: 'Through data collaboration & advocacy',
              borderColor: 'border-gold-light/40',
              accentColor: 'text-gold-light',
              glowColor: 'from-gold-light/25 to-gold/10',
            },
          ].map((stat, i) => (
            <div key={i} class="scroll-reveal" style={`--delay: ${i * 100}ms`}>
              <div class="relative group">
                <div class={`absolute -inset-2 bg-gradient-to-r ${stat.glowColor} rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl`}></div>
                <div class={`relative bg-charcoal/50 border ${stat.borderColor} rounded-2xl p-8 backdrop-blur-sm hover:border-opacity-100 transition-colors duration-300`}>
                  <div class={`text-5xl font-black ${stat.accentColor} mb-3`}>{stat.number}</div>
                  <div class="text-lg font-bold text-cream mb-2">{stat.label}</div>
                  <p class="text-cream/70 text-sm">{stat.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stories Section -->
    <section class="min-h-screen py-32 px-4 md:px-12 bg-gradient-to-b from-charcoal to-black relative z-20">
      <div class="max-w-6xl mx-auto">
        <div class="mb-20">
          <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6 scroll-reveal">
            Real Stories
          </div>
          <h2 class="text-6xl md:text-7xl font-black text-cream leading-tight scroll-reveal" style="letter-spacing: -2px;">
            Voices of Hope
          </h2>
        </div>

        <div class="space-y-16">
          {[
            {
              title: 'From Survivor to Advocate',
              desc: 'After 8 years in exploitation, Amara escaped with help from our local partners in Phnom Penh. Now she leads survivor support groups and mentors 12 young women rebuilding their lives.',
              region: 'Cambodia',
            },
            {
              title: 'The Kibera Collective',
              desc: 'Founded by trafficking survivors, this Nairobi-based organization uses our network to place 340 survivors into sustainable employment while providing childcare and mental health services.',
              region: 'Kenya',
            },
            {
              title: 'Justice Across Borders',
              desc: 'Since 2019, our data-sharing platform has enabled law enforcement across 18 countries to coordinate investigations. Result: 203 convictions, 847 survivors identified and supported.',
              region: 'Global Network',
            },
          ].map((story, i) => (
            <div key={i} class="scroll-reveal" style={`--delay: ${i * 150}ms`}>
              <div class="group relative">
                <div class="absolute -inset-4 bg-gradient-to-r from-gold/10 to-mauve/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-lg"></div>
                <div class="relative bg-charcoal border border-gold/20 rounded-2xl p-8 md:p-12 group-hover:border-gold/50 transition-colors duration-300">
                  <div class="flex items-start justify-between mb-6">
                    <h3 class="text-2xl md:text-3xl font-bold text-gold">{story.title}</h3>
                    <span class="text-cream/60 text-sm uppercase tracking-wider font-semibold">{story.region}</span>
                  </div>
                  <p class="text-lg text-cream/80 leading-relaxed">{story.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section id="action" class="min-h-screen py-32 px-4 md:px-12 flex items-center justify-center relative z-20">
      <div class="max-w-4xl mx-auto text-center">
        <div class="scroll-reveal mb-8">
          <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
            Join the Movement
          </div>
          <h2 class="text-7xl md:text-8xl font-black text-cream leading-tight mb-8" style="letter-spacing: -2px;">
            Every Voice Matters
          </h2>
          <p class="text-xl text-cream/80 max-w-2xl mx-auto mb-12">
            Whether you're an advocate, survivor, organization, or concerned citizen—there's a role for you in this movement toward universal freedom.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 scroll-reveal">
          {[
            {
              title: 'Donate',
              desc: 'Financial support funds direct services to survivors and advocacy programs.',
              icon: '💝',
              color: 'border-gold',
              accentColor: 'text-gold'
            },
            {
              title: 'Volunteer',
              desc: 'Share your professional expertise in legal, tech, or social services.',
              icon: '🤝',
              color: 'border-mauve',
              accentColor: 'text-mauve-light'
            },
            {
              title: 'Partner',
              desc: 'Collaborate on research, policy, or direct survivor support programs.',
              icon: '🌐',
              color: 'border-gold-light',
              accentColor: 'text-gold-light'
            },
          ].map((item) => (
            <div key={item.title} class={`relative group bg-charcoal/50 border ${item.color}/40 rounded-2xl p-8 hover:border-opacity-100 transition-all duration-300 backdrop-blur-sm hover:shadow-lg hover:shadow-gold/20`}>
              <div class={`text-5xl mb-4 group-hover:scale-110 transition-transform duration-300`}>{item.icon}</div>
              <h3 class={`text-2xl font-bold ${item.accentColor} mb-2`}>{item.title}</h3>
              <p class="text-cream/70 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

        <div class="flex flex-col md:flex-row gap-6 justify-center scroll-reveal">
          <a href="/get-involved" class="px-12 py-5 bg-gold text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-wider shadow-lg hover:shadow-xl text-center">
            Take Action Now
          </a>
          <a href="/about" class="px-12 py-5 border-2 border-gold text-gold font-bold rounded-full hover:bg-gold hover:text-black transition-all duration-200 uppercase text-sm tracking-wider text-center">
            Learn About Our Work
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black border-t border-gold/20 py-16 px-4 relative z-20">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
          <div>
            <h3 class="text-gold font-bold mb-4 uppercase tracking-wider">Unchained</h3>
            <p class="text-cream/60 text-sm">Ending human trafficking and modern slavery worldwide.</p>
          </div>
          <div>
            <h4 class="text-cream font-bold mb-4 uppercase tracking-wider text-xs">Site</h4>
            <ul class="space-y-2 text-sm text-cream/60">
              <li><a href="/#impact" class="hover:text-gold transition">Our Impact</a></li>
              <li><a href="/#action" class="hover:text-gold transition">Get Involved</a></li>
              <li><a href="/resources" class="hover:text-gold transition">Resources</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-cream font-bold mb-4 uppercase tracking-wider text-xs">Follow</h4>
            <ul class="space-y-2 text-sm text-cream/60">
              <li><a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition">Twitter →</a></li>
              <li><a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition">Instagram →</a></li>
              <li><a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition">LinkedIn →</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-cream font-bold mb-4 uppercase tracking-wider text-xs">Legal</h4>
            <ul class="space-y-2 text-sm text-cream/60">
              <li><a href="/privacy" class="hover:text-gold transition">Privacy Policy</a></li>
              <li><a href="/terms" class="hover:text-gold transition">Terms of Service</a></li>
              <li><a href="mailto:hello@freedom.org" class="hover:text-gold transition">hello@freedom.org</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gold/20 pt-8 text-center text-cream/60 text-sm">
          <p>&copy; 2026 Unchained. All rights reserved. Built with purpose.</p>
          <p class="mt-4 text-xs text-cream/50">
            Made by <a href="https://www.sprucemysite.com.au" target="_blank" rel="noopener noreferrer" class="text-gold hover:text-gold-light transition">SpruceMySite</a>
          </p>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  .animate-bounce {
    animation: bounce 2s infinite;
  }

  .scroll-reveal {
    opacity: 0;
    transform: translateY(32px);
    animation: fadeInUp 0.8s cubic-bezier(0.23, 1, 0.32, 1) both;
    --delay: 0ms;
    animation-delay: var(--delay);
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal,
    .animate-fade-in-up,
    .animate-bounce {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* Button states */
  button, a.button-like {
    transition: transform 200ms var(--ease-out), box-shadow 200ms var(--ease-out);
  }

  button:active, a.button-like:active {
    transform: scale(0.97);
  }

  button:focus-visible, a.button-like:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll-triggered reveals
  document.querySelectorAll('.scroll-reveal').forEach((element) => {
    gsap.to(element, {
      scrollTrigger: {
        trigger: element,
        start: 'top 80%',
        end: 'top 20%',
        toggleActions: 'play none none reverse',
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'cubic-bezier(0.23, 1, 0.32, 1)',
    });
  });

  // Parallax effect on sections
  gsap.utils.toArray<HTMLElement>('section').forEach((section) => {
    gsap.to(section, {
      scrollTrigger: {
        trigger: section,
        start: 'top center',
        end: 'bottom center',
        markers: false,
      },
      y: (i, target) => {
        return window.innerHeight * 0.05;
      },
      duration: 1,
      ease: 'power1.inOut',
    });
  });
</script>
