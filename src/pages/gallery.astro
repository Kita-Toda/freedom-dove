---
import Layout from '../layouts/Layout.astro';
import ImageGallery from '../components/ui/ImageGallery';

const galleryImages = [
  {
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    title: 'Community Support',
    description: 'Local organizations providing direct aid and resources',
    category: 'Impact',
    href: '/gallery/community',
  },
  {
    image: 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&h=400&fit=crop',
    title: 'Global Network',
    description: 'Partners working across 31 countries worldwide',
    category: 'Network',
    href: '/gallery/network',
  },
  {
    image: 'https://images.unsplash.com/photo-1531482615713-2afd69097998?w=600&h=400&fit=crop',
    title: 'Survivor Stories',
    description: 'Voices of hope and resilience from around the world',
    category: 'Stories',
    href: '/gallery/stories',
  },
  {
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    title: 'Training Programs',
    description: 'Empowering individuals with skills and opportunities',
    category: 'Education',
    href: '/gallery/education',
  },
  {
    image: 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&h=400&fit=crop',
    title: 'Advocacy Campaign',
    description: 'Raising awareness and demanding systemic change',
    category: 'Advocacy',
    href: '/gallery/advocacy',
  },
  {
    image: 'https://images.unsplash.com/photo-1531482615713-2afd69097998?w=600&h=400&fit=crop',
    title: 'Safe Spaces',
    description: 'Providing security, shelter, and comprehensive support',
    category: 'Support',
    href: '/gallery/support',
  },
  {
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    title: 'Justice System',
    description: 'Working with law enforcement for accountability',
    category: 'Advocacy',
    href: '/gallery/justice',
  },
  {
    image: 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&h=400&fit=crop',
    title: 'Medical Care',
    description: 'Health services and recovery support for survivors',
    category: 'Support',
    href: '/gallery/medical',
  },
  {
    image: 'https://images.unsplash.com/photo-1531482615713-2afd69097998?w=600&h=400&fit=crop',
    title: 'Legal Aid',
    description: 'Supporting survivors through legal processes',
    category: 'Support',
    href: '/gallery/legal',
  },
];
---

<Layout title="Gallery — Unchained">
  <!-- Skip Link -->
  <a href="#gallery" class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-[999] focus:bg-gold focus:text-black focus:px-4 focus:py-2 focus:font-bold">
    Skip to gallery
  </a>

  <!-- Hero Section -->
  <section class="min-h-96 py-20 px-4 md:px-12 bg-gradient-to-b from-black to-charcoal flex items-center justify-center">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
        Visual Stories
      </div>
      <h1 class="text-6xl md:text-7xl font-black text-cream leading-tight mb-8" style="letter-spacing: -2px;">
        Our Work in Action
      </h1>
      <p class="text-xl text-cream/80 max-w-2xl mx-auto">
        Explore the diverse ways we're working to end human trafficking and modern slavery worldwide. These images represent the real impact of our global network.
      </p>
    </div>
  </section>

  <!-- Gallery Section -->
  <section id="gallery" class="relative">
    <ImageGallery
      images={galleryImages}
      columns={3}
      category="Impact Gallery"
      title="Our Impact in Action"
      description="Projects, partnerships, and survivors we support across 31 countries"
      showOverlay={true}
    />
  </section>

  <!-- Call to Action Section -->
  <section class="py-20 px-4 md:px-12 bg-gradient-to-b from-charcoal to-black">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
        Inspired by our work?
      </div>
      <h2 class="text-5xl md:text-6xl font-black text-cream leading-tight mb-8" style="letter-spacing: -2px;">
        Get Involved Today
      </h2>
      <p class="text-xl text-cream/80 max-w-2xl mx-auto mb-12">
        Your support helps us continue this vital work. Whether you donate, volunteer, or advocate, every contribution matters.
      </p>
      <div class="flex flex-col md:flex-row gap-6 justify-center">
        <a href="/get-involved" class="px-12 py-5 bg-gold text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-wider shadow-lg hover:shadow-xl">
          Take Action Now →
        </a>
        <a href="/about" class="px-12 py-5 border-2 border-gold text-gold font-bold rounded-full hover:bg-gold hover:text-black transition-all duration-200 uppercase text-sm tracking-wider">
          Learn More →
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  section {
    scroll-behavior: smooth;
  }
</style>
