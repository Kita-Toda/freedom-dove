---
import Layout from '../layouts/Layout.astro';
import MediaCard from '../components/ui/MediaCard';
import soniaPortrait from '../images/Sonia_Qutami1.jpg';
import soniaSpeaking from '../images/Sonia_Qutami2.jpg';
---

<Layout title="Founder — Sonia Qutami | Unchained">
  <div class="min-h-screen bg-gradient-to-b from-black to-charcoal py-32 px-4 md:px-12">
    <!-- Hero Section -->
    <section class="mb-32">
      <div class="max-w-6xl mx-auto">
        <div class="text-gold text-xs uppercase tracking-[0.2em] font-semibold opacity-80 mb-6">
          Meet Our Founder
        </div>
        <h1 class="text-7xl md:text-8xl font-black text-cream leading-tight mb-8" style="letter-spacing: -2px;">
          Sonia Qutami
        </h1>
        <p class="text-2xl text-cream/80 max-w-3xl mb-12 leading-relaxed">
          Visionary leader, survivor advocate, and the driving force behind Unchained's global movement to end human trafficking.
        </p>
      </div>
    </section>

    <!-- Image Gallery Section -->
    <section class="mb-32 max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
        <!-- Image 1 with Creative Card -->
        <div class="group">
          <div class="relative overflow-hidden rounded-3xl border-2 border-gold/30 hover:border-gold/60 transition-all duration-300 h-full">
            <img
              src={soniaPortrait.src}
              alt="Sonia Qutami - Founder of Unchained"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-8">
                <p class="text-cream text-lg font-semibold">Visionary Leadership</p>
                <p class="text-cream/70 text-sm">Shaping the future of human rights</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Image 2 with Creative Card -->
        <div class="group">
          <div class="relative overflow-hidden rounded-3xl border-2 border-mauve/30 hover:border-mauve/60 transition-all duration-300 h-full">
            <img
              src={soniaSpeaking.src}
              alt="Sonia Qutami Speaking At Event"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-8">
                <p class="text-cream text-lg font-semibold">Global Advocacy</p>
                <p class="text-cream/70 text-sm">Leading change across 31 countries</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Biography Section -->
    <section class="mb-32 max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Main Bio -->
        <div class="md:col-span-2">
          <h2 class="text-5xl font-bold text-cream mb-8">Her Story</h2>

          <div class="space-y-6 text-cream/80 text-lg leading-relaxed">
            <p>
              Sonia Qutami's journey as a survivor and advocate has transformed into a global movement. After escaping her own trafficking situation, she dedicated her life to ensuring no one would face the same horrors alone.
            </p>

            <p>
              In 2018, she founded Unchained with a simple but powerful mission: to connect survivors, advocacy organizations, and law enforcement across borders. What started as a network of 50 people has grown into a global coalition spanning 31 countries, supporting over 127,000 survivors, and securing 847 convictions.
            </p>

            <p>
              Her work extends beyond direct services. Sonia spearheads policy advocacy at the international level, advises governments on anti-trafficking legislation, and leads research that informs global strategy. Her approach is survivor-led, data-driven, and unapologetically bold.
            </p>
          </div>
        </div>

        <!-- Stats Cards -->
        <div class="space-y-8">
          <div class="bg-charcoal/50 border-2 border-gold/30 rounded-2xl p-8 hover:border-gold/60 transition-colors duration-300">
            <div class="text-4xl font-black text-gold mb-3">2018</div>
            <div class="text-cream font-bold mb-2">Founded Unchained</div>
            <div class="text-cream/70 text-sm">Sparked a global movement</div>
          </div>

          <div class="bg-charcoal/50 border-2 border-mauve/30 rounded-2xl p-8 hover:border-mauve/60 transition-colors duration-300">
            <div class="text-4xl font-black text-mauve-light mb-3">31</div>
            <div class="text-cream font-bold mb-2">Countries</div>
            <div class="text-cream/70 text-sm">Active coalition members</div>
          </div>

          <div class="bg-charcoal/50 border-2 border-gold-light/30 rounded-2xl p-8 hover:border-gold-light/60 transition-colors duration-300">
            <div class="text-4xl font-black text-gold-light mb-3">127K+</div>
            <div class="text-cream font-bold mb-2">Survivors Supported</div>
            <div class="text-cream/70 text-sm">Lives transformed</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Impact Pillars -->
    <section class="mb-32 max-w-6xl mx-auto border-t border-gold/20 pt-20">
      <h2 class="text-5xl font-bold text-cream mb-16 text-center">Sonia's Four Pillars</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="group relative bg-charcoal/50 border-2 border-gold/30 rounded-2xl p-8 hover:border-gold/60 hover:bg-charcoal/70 transition-all duration-300">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">🛡️</div>
          <h3 class="text-xl font-bold text-gold mb-4">Survivor Protection</h3>
          <p class="text-cream/70">Direct services, safe housing, and comprehensive support</p>
        </div>

        <div class="group relative bg-charcoal/50 border-2 border-mauve/30 rounded-2xl p-8 hover:border-mauve/60 hover:bg-charcoal/70 transition-all duration-300">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">⚖️</div>
          <h3 class="text-xl font-bold text-mauve-light mb-4">Justice & Accountability</h3>
          <p class="text-cream/70">Law enforcement coordination, prosecutions, convictions</p>
        </div>

        <div class="group relative bg-charcoal/50 border-2 border-gold-light/30 rounded-2xl p-8 hover:border-gold-light/60 hover:bg-charcoal/70 transition-all duration-300">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">📊</div>
          <h3 class="text-xl font-bold text-gold-light mb-4">Data & Intelligence</h3>
          <p class="text-cream/70">Research-driven insights, pattern mapping, strategic planning</p>
        </div>

        <div class="group relative bg-charcoal/50 border-2 border-cream/30 rounded-2xl p-8 hover:border-cream/60 hover:bg-charcoal/70 transition-all duration-300">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">🌍</div>
          <h3 class="text-xl font-bold text-cream mb-4">Global Advocacy</h3>
          <p class="text-cream/70">Policy change, international partnerships, systemic reform</p>
        </div>
      </div>
    </section>

    <!-- Vision Statement -->
    <section class="mb-32 max-w-4xl mx-auto">
      <div class="relative bg-gradient-to-br from-charcoal/50 to-black/50 border-2 border-gold/30 rounded-3xl p-16 text-center">
        <div class="text-gold text-5xl mb-8">💫</div>
        <h2 class="text-4xl font-bold text-cream mb-8" style="letter-spacing: -1px;">Sonia's Vision</h2>
        <p class="text-xl text-cream/80 leading-relaxed mb-0">
          "A world where freedom is not a privilege but a universal right. Where survivors are heard, supported, and empowered. Where traffickers face justice across every border. Where governments, organizations, and citizens stand united against exploitation. This is the Unchained future we're building together."
        </p>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="max-w-4xl mx-auto text-center">
      <h2 class="text-5xl font-bold text-cream mb-8">Join Sonia's Movement</h2>
      <p class="text-lg text-cream/80 mb-12 max-w-2xl mx-auto">
        Every action contributes to freedom. Whether you donate, volunteer, advocate, or partner with us—you're part of something transformative.
      </p>
      <div class="flex flex-col md:flex-row gap-6 justify-center">
        <a href="/get-involved" class="px-12 py-5 bg-gold text-black font-bold rounded-full hover:scale-[1.02] transition-transform duration-200 uppercase text-sm tracking-[0.75px] shadow-lg">
          Get Involved Today
        </a>
        <a href="/about" class="px-12 py-5 border-2 border-gold text-gold font-bold rounded-full hover:bg-gold hover:text-black transition-all duration-200 uppercase text-sm tracking-[0.75px]">
          Learn About Unchained
        </a>
      </div>
    </section>
  </div>
</Layout>

<style>
  section {
    scroll-behavior: smooth;
  }
</style>
